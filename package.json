{
  "name": "loys-|-celestial-art-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev dist",
    "build": "vite build",
    "preview": "wrangler pages dev dist --compatibility-date=2024-11-01",
    "deploy": "npm run build && wrangler pages deploy",
    "lint": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply loys_art --remote",
    "db:migrate:local": "wrangler d1 migrations apply loys_art --local",
    "seed:sql": "node scripts/generate-seed-sql.mjs"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@esbuild/win32-x64": "^0.28.0",
    "@formspree/react": "^3.0.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.4",
    "@tailwindcss/vite": "^4.2.2",
    "esbuild": "^0.28.0",
    "lucide-react": "^0.477.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.14.0"
  }
}
